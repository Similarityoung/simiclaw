# LLM API 配置
# 将本文件复制为 .env 并填入真实密钥：
#   cp .env.example .env
#
# .env 不会被 git 追踪（已在 .gitignore 中忽略）。
# 真实的环境变量（如 CI/CD 注入的）优先级高于本文件。

# OpenAI 兼容 API 密钥（必填）
LLM_API_KEY=your_api_key_here

# API Base URL（可选，默认 https://api.openai.com/v1）
# 兼容 DeepSeek、Ollama、OpenRouter 等任意 OpenAI 兼容接口
# LLM_BASE_URL=https://api.openai.com/v1

# 模型名称（可选，默认 gpt-4o）
# LLM_MODEL=gpt-4o
